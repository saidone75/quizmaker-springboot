<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-teacher-image-upload-preference-default" author="quizmaker" dbms="h2,postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="teachers"/>
                <not>
                    <columnExists tableName="teachers" columnName="image_upload_enabled"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="teachers">
            <column name="image_upload_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="teachers" columnName="image_upload_enabled"/>
        </rollback>
    </changeSet>

    <changeSet id="005-teacher-image-upload-preference-sqlite" author="quizmaker" dbms="sqlite">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="teachers"/>
                <not>
                    <columnExists tableName="teachers" columnName="image_upload_enabled"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="teachers">
            <column name="image_upload_enabled" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="teachers" columnName="image_upload_enabled"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
