<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-teacher-image-search-mode-preference-default" author="quizmaker" dbms="h2,postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="teachers"/>
                <not>
                    <columnExists tableName="teachers" columnName="image_search_mode"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="teachers">
            <column name="image_search_mode" type="VARCHAR(16)" defaultValue="advanced">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="teachers" columnName="image_search_mode"/>
        </rollback>
    </changeSet>

    <changeSet id="006-teacher-image-search-mode-preference-sqlite" author="quizmaker" dbms="sqlite">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="teachers"/>
                <not>
                    <columnExists tableName="teachers" columnName="image_search_mode"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="teachers">
            <column name="image_search_mode" type="TEXT" defaultValue="advanced">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="teachers" columnName="image_search_mode"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
